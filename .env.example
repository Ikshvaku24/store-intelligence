
# --- Database ---
# Docker/production (Postgres). For local dev without a server you may instead use:
#   DB_URL=sqlite:///./store_intelligence.db
DB_URL=postgresql+psycopg://store:store@postgres:5432/store_intelligence

# --- API limits ---
MAX_BATCH_SIZE=500

# --- Conversion / POS correlation ---
POS_CORRELATION_WINDOW_MIN=5

# --- Anomaly thresholds ---
QUEUE_SPIKE_THRESHOLD=4
DEAD_ZONE_WINDOW_MIN=5
CONVERSION_DROP_PCT=0.30
CONVERSION_MIN_HISTORY_MIN=30

# --- Health ---
STALE_FEED_MIN=10

# --- Heatmap ---
HEATMAP_MIN_SESSIONS=20

# --- Metrics ---
DEFAULT_METRICS_WINDOW_MIN=60

# --- Store layout (open hours / zone names) ---
STORE_LAYOUT_PATH=data/store_layout.json

# --- Dashboard ---
DASHBOARD_PORT=8080

GEMINI_API_KEY=your_gemini_api_key_here
VLM_STAFF_CACHE=data/vlm_staff_cache.json
GEMINI_MODEL=gemini-2.5-flash